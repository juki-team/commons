{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "extends": ["./biome.shared.json"],
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": false
  },
  "overrides": [
    {
      "includes": ["src/prisma/enums/**"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": {
              "level": "error",
              "options": {
                "strictCase": false,
                "conventions": [
                  {
                    "selector": { "kind": "objectLiteralProperty" },
                    "formats": ["CONSTANT_CASE"]
                  },
                  {
                    "selector": { "kind": "enumMember" },
                    "formats": ["CONSTANT_CASE"]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["*.config.ts"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
